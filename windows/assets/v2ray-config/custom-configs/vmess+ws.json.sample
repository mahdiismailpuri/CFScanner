{
  "inbounds": [
{
    "port": "PORTPORT", 
    "listen": "127.0.0.1",
    "tag": "socks-inbound",
    "protocol": "socks",
    "settings": {
      "auth": "noauth",
      "udp": false,
      "ip": "127.0.0.1"
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    }
  }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [{"address": "IP.IP.IP.IP",
            "port": 443,
            "users": [{"id": "968749b7-4ea1-4aad-af3b-44165298cade",
            "encryption": "none"}]}]
      },
      "streamSettings": {
        "network": "httpupgrade",
        "security": "tls",
        "tlsSettings": {
          "serverName": "onvip9.ir",
          "allowInsecure": true,
          "fingerprint": "chrome",
          "alpn": [
            "http/1.1"
          ]
        },
        "httpupgradeSettings": {
          "headers": {
            "Pragma": "no-cache",
            "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:125.0) Gecko/20100101 Firefox/125.0"
          },
          "path": "?ed=2560",
          "host": "onvip9.ir"
        }
      }
    }
  ],
"other": {}
}
